<Window
    x:Class="Shruti.App.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Shruti">
    <Grid
        x:Name="Root"
        MinWidth="800"
        MinHeight="620"
        Background="{ThemeResource ShrutiRootBrush}">
        <Grid.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{ThemeResource ShrutiTextBrush}" />
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ShrutiSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ShrutiBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{ThemeResource ShrutiMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="184" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.ColumnSpan="2"
            Padding="16,0,140,0"
            Background="{ThemeResource ShrutiRootBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border
                    Width="20"
                    Height="20"
                    Background="{ThemeResource ShrutiAccentBrush}"
                    CornerRadius="10">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="11"
                        Foreground="{ThemeResource ShrutiAccentForegroundBrush}"
                        Glyph="&#xE720;" />
                </Border>
                <TextBlock
                    FontFamily="Segoe UI Variable Text, Segoe UI"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource ShrutiTextBrush}"
                    Text="Shruti" />
                <TextBlock
                    FontFamily="Segoe UI Variable Text, Segoe UI"
                    FontSize="12"
                    Foreground="{ThemeResource ShrutiMutedTextBrush}"
                    Text="Local dictation" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Background="{ThemeResource ShrutiSidebarBrush}"
            BorderBrush="{ThemeResource ShrutiBorderBrush}"
            BorderThickness="0,0,1,0">
            <Grid Padding="14,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border
                            Width="32"
                            Height="32"
                            Background="{ThemeResource ShrutiAccentBrush}"
                            CornerRadius="16">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{ThemeResource ShrutiAccentForegroundBrush}"
                                Glyph="&#xE720;" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="0">
                            <TextBlock
                                FontFamily="Segoe UI Variable Display, Segoe UI"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource ShrutiTextBrush}"
                                Text="Shruti" />
                            <TextBlock
                                FontSize="10.5"
                                Foreground="{ThemeResource ShrutiMutedTextBrush}"
                                Text="LOCAL DICTATION" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,32,0,0" VerticalAlignment="Top">
                    <Button
                        x:Name="HomeNavButton"
                        AutomationProperties.Name="Home"
                        Style="{StaticResource NavButtonStyle}"
                        Tag="Home"
                        ToolTipService.ToolTip="Home"
                        Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="11">
                            <FontIcon FontFamily="Segoe Fluent Icons" FontSize="16" Glyph="&#xE80F;" />
                            <TextBlock FontSize="13.5" Text="Home" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="HistoryNavButton"
                        AutomationProperties.Name="History"
                        Style="{StaticResource NavButtonStyle}"
                        Tag="History"
                        ToolTipService.ToolTip="History"
                        Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="11">
                            <FontIcon FontFamily="Segoe Fluent Icons" FontSize="16" Glyph="&#xE81C;" />
                            <TextBlock FontSize="13.5" Text="History" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="ModelsNavButton"
                        AutomationProperties.Name="Models"
                        Style="{StaticResource NavButtonStyle}"
                        Tag="Models"
                        ToolTipService.ToolTip="Models"
                        Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="11">
                            <FontIcon FontFamily="Segoe Fluent Icons" FontSize="16" Glyph="&#xE7B8;" />
                            <TextBlock FontSize="13.5" Text="Models" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="SettingsNavButton"
                        AutomationProperties.Name="Settings"
                        Style="{StaticResource NavButtonStyle}"
                        Tag="Settings"
                        ToolTipService.ToolTip="Settings"
                        Click="NavigationButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="11">
                            <FontIcon FontFamily="Segoe Fluent Icons" FontSize="16" Glyph="&#xE713;" />
                            <TextBlock FontSize="13.5" Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    Grid.Row="2"
                    Padding="10"
                    Background="{ThemeResource ShrutiSurfaceLowBrush}"
                    CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            Foreground="{ThemeResource ShrutiAccentBrush}"
                            FontFamily="Segoe Fluent Icons"
                            Glyph="&#xE895;" />
                        <StackPanel Spacing="1">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="On device" />
                            <TextBlock FontSize="11" Style="{StaticResource MutedTextStyle}" Text="Audio stays local" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Padding="32,26,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock
                        x:Name="PageTitleText"
                        FontFamily="Segoe UI Variable Display, Segoe UI"
                        FontSize="23"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource ShrutiTextBrush}"
                        LineHeight="29"
                        Text="Ready to dictate" />
                    <TextBlock
                        x:Name="PageSubtitleText"
                        FontSize="13"
                        Style="{StaticResource MutedTextStyle}"
                        Text="Hold your shortcut, speak naturally, and release to finish." />
                </StackPanel>
                <Border
                    Grid.Column="1"
                    MinHeight="34"
                    Padding="10,6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{ThemeResource ShrutiSurfaceLowBrush}"
                    BorderBrush="{ThemeResource ShrutiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <Grid
                        ColumnSpacing="7"
                        VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse
                            Width="8"
                            Height="8"
                            VerticalAlignment="Center"
                            Fill="{ThemeResource ShrutiSuccessBrush}" />
                        <TextBlock
                            x:Name="StatusPillText"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Ready" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="HomePage" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Padding="0,24,0,0" Spacing="18">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}" Padding="13">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="28" Height="28" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="14">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShrutiAccentBrush}" Glyph="&#xE720;" />
                                    </Border>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Microphone" />
                                        <TextBlock x:Name="MicrophoneReadinessText" FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Checking device" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="13">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="28" Height="28" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="14">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShrutiAccentBrush}" Glyph="&#xE7B8;" />
                                    </Border>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Model" />
                                        <TextBlock x:Name="ModelSummaryText" FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Whisper tiny.en" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="13">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="28" Height="28" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="14">
                                        <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{ThemeResource ShrutiAccentBrush}" Glyph="&#xE73E;" />
                                    </Border>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Backend" />
                                        <TextBlock x:Name="BackendSummaryText" FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Checking readiness" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="22">
                            <Grid ColumnSpacing="28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="260" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="13">
                                    <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="19" FontWeight="SemiBold" Text="Dictation" />
                                    <TextBlock
                                        x:Name="StatusText"
                                        AutomationProperties.LiveSetting="Polite"
                                        FontSize="13"
                                        Foreground="{ThemeResource ShrutiMutedTextBrush}"
                                        Text="Ready when you are." />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Button
                                            x:Name="PrimaryDictationButton"
                                            AutomationProperties.HelpText="Start recording from the selected microphone, or stop an active dictation."
                                            AutomationProperties.Name="Start dictation"
                                            Width="190"
                                            Height="44"
                                            Background="{ThemeResource ShrutiAccentBrush}"
                                            Foreground="{ThemeResource ShrutiAccentForegroundBrush}"
                                            Click="PrimaryDictationButton_Click">
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="9">
                                                <FontIcon x:Name="PrimaryButtonIcon" FontFamily="Segoe Fluent Icons" FontSize="16" Glyph="&#xE720;" />
                                                <TextBlock x:Name="PrimaryButtonLabel" FontSize="13" FontWeight="SemiBold" Text="Start dictation" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            x:Name="PauseButton"
                                            AutomationProperties.Name="Pause recording"
                                            Height="44"
                                            Padding="14,0"
                                            Click="PauseButton_Click">
                                            <TextBlock x:Name="PauseButtonLabel" FontSize="13" Text="Pause" />
                                        </Button>
                                        <Button
                                            x:Name="CancelButton"
                                            AutomationProperties.HelpText="Cancel the current dictation without inserting text."
                                            AutomationProperties.Name="Cancel dictation"
                                            Height="44"
                                            Padding="14,0"
                                            Click="CancelButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" />
                                                <TextBlock FontSize="13" Text="Cancel" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Padding="8,4" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="4">
                                            <TextBlock x:Name="StateText" FontSize="12" Text="Idle" />
                                        </Border>
                                        <Border Padding="8,4" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="4">
                                            <TextBlock x:Name="TargetText" FontSize="12" Text="No target captured" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="10">
                                    <TextBlock FontSize="12" Foreground="{ThemeResource ShrutiMutedTextBrush}" Text="INSERTION MODE" />
                                    <ComboBox
                                        x:Name="InsertionModeComboBox"
                                        AutomationProperties.HelpText="Choose whether Shruti inserts text automatically, shows a preview first, or only copies the transcript."
                                        AutomationProperties.Name="Insertion mode"
                                        SelectionChanged="InsertionModeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Auto-insert" Tag="AutoInsert" />
                                        <ComboBoxItem Content="Preview first" Tag="PreviewFirst" />
                                        <ComboBoxItem Content="Copy only" Tag="CopyOnly" />
                                    </ComboBox>
                                    <TextBlock Style="{StaticResource MutedTextStyle}" FontSize="12" Text="Auto-insert returns focus to the captured target after transcription." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Live transcript" />
                                        <TextBlock x:Name="UserMessageText" AutomationProperties.LiveSetting="Polite" FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Dictation is ready." />
                                    </StackPanel>
                                    <ProgressBar
                                        x:Name="AudioLevelBar"
                                        AutomationProperties.Name="Microphone input level"
                                        Grid.Column="1"
                                        Width="118"
                                        Height="6"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0" />
                                </Grid>
                                <TextBox
                                    x:Name="TranscriptPreviewBox"
                                    AutomationProperties.HelpText="Transcript text is omitted from diagnostics by default."
                                    AutomationProperties.Name="Transcript preview"
                                    MinHeight="118"
                                    AcceptsReturn="True"
                                    Background="{ThemeResource ShrutiSurfaceLowBrush}"
                                    BorderBrush="{ThemeResource ShrutiBorderBrush}"
                                    Foreground="{ThemeResource ShrutiTextBrush}"
                                    IsReadOnly="True"
                                    PlaceholderText="Your transcript will appear here while you dictate."
                                    TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <CheckBox
                                        x:Name="ReplaceSelectionCheckBox"
                                        AutomationProperties.HelpText="Allow preview insertion to replace selected text in the target app."
                                        Content="Replace selected text"
                                        Visibility="Collapsed" />
                                    <Button x:Name="CopyButton" AutomationProperties.Name="Copy transcript" Click="CopyButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" />
                                            <TextBlock Text="Copy" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="InsertPreviewButton" AutomationProperties.Name="Insert preview transcript" Click="InsertPreviewButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A7;" />
                                            <TextBlock Text="Insert" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="RetryButton" AutomationProperties.Name="Retry dictation" Click="RetryButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" />
                                            <TextBlock Text="Retry" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock
                                    x:Name="ErrorText"
                                    AutomationProperties.LiveSetting="Assertive"
                                    Foreground="{ThemeResource ShrutiCriticalBrush}"
                                    TextWrapping="Wrap"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="Hold to dictate" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}" FontSize="12" Text="Start with your configured shortcut and release it to finish and insert." />
                                </StackPanel>
                                <Border Grid.Column="1" Padding="10,5" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="4">
                                    <TextBlock x:Name="HoldShortcutText" FontWeight="SemiBold" Text="Ctrl+Win+Space" />
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Spacing="10">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Recent dictations" />
                            <TextBlock Style="{StaticResource MutedTextStyle}" FontSize="12" Text="Mock data. Transcript history will be enabled when local history storage is implemented." />
                            <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Project update notes and next steps" />
                                        <TextBlock FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Mock transcript - 28 words" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Style="{StaticResource MutedTextStyle}" FontSize="12" Text="Today" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="HistoryPage" Padding="0,28,0,0" Visibility="Collapsed" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="18">
                        <Border Style="{StaticResource CardBorderStyle}" Padding="18" Background="{ThemeResource ShrutiSurfaceLowBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontFamily="Segoe Fluent Icons" Foreground="{ThemeResource ShrutiAccentBrush}" Glyph="&#xE946;" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="Mock data. Transcript history will be enabled when local history storage is implemented." />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Project update notes and next steps" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="Mock transcript: Review the current milestone, confirm the release target, and send the follow-up notes." />
                                <TextBlock FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Today, 10:42 AM - 28 words - Auto-insert" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Draft response for the design review" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="Mock transcript: Thanks for the handoff. I will verify the workflow and share the implementation plan." />
                                <TextBlock FontSize="12" Style="{StaticResource MutedTextStyle}" Text="Yesterday, 4:16 PM - 19 words - Preview first" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="ModelsPage" Padding="0,28,0,0" Visibility="Collapsed" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="18">
                        <Border Style="{StaticResource CardBorderStyle}" Padding="18" Background="{ThemeResource ShrutiSurfaceLowBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon FontFamily="Segoe Fluent Icons" Foreground="{ThemeResource ShrutiAccentBrush}" Glyph="&#xE946;" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="Mock data. Model selection and downloads will be enabled when the model-management UI is wired." />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="5">
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="Whisper tiny.en" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}" FontSize="12" Text="English - fastest - 75 MB - used by the current local transcription flow" />
                                </StackPanel>
                                <Border Grid.Column="1" Padding="8,4" Background="{ThemeResource ShrutiSurfaceLowBrush}" CornerRadius="4">
                                    <TextBlock Foreground="{ThemeResource ShrutiSuccessBrush}" Text="Selected" />
                                </Border>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="5">
                                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="Whisper base.en" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}" FontSize="12" Text="English - higher accuracy - 142 MB - mock catalog entry" />
                                </StackPanel>
                                <Button Grid.Column="1" IsEnabled="False" ToolTipService.ToolTip="Model downloads are not implemented yet" Content="Download" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SettingsPanel" Padding="0,28,0,0" Visibility="Collapsed" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="20">
                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="13">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Appearance" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ThemeComboBox" Header="Theme" SelectionChanged="ThemeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Use Windows setting" Tag="Default" />
                                        <ComboBoxItem Content="Light" Tag="Light" />
                                        <ComboBoxItem Content="Dark" Tag="Dark" />
                                    </ComboBox>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Bottom" Style="{StaticResource MutedTextStyle}" FontSize="12" Text="System detection is the default. Your choice is saved locally." />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Privacy and diagnostics" />
                                <TextBlock
                                    Style="{StaticResource MutedTextStyle}"
                                    FontSize="12"
                                    Text="Shruti records and transcribes locally. Diagnostics describe state, model/backend readiness, microphone status, and insertion outcomes; transcript text is omitted by default." />
                                <TextBlock
                                    Style="{StaticResource MutedTextStyle}"
                                    FontSize="12"
                                    Text="If microphone access fails, open Windows Settings &gt; Privacy &amp; security &gt; Microphone and allow Shruti and desktop apps." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Diagnostics snapshot" />
                                <TextBlock
                                    x:Name="DiagnosticsSnapshotText"
                                    AutomationProperties.Name="Latest redacted diagnostics snapshot"
                                    Style="{StaticResource MutedTextStyle}"
                                    FontSize="12"
                                    Text="Run dictation to populate a redacted diagnostics snapshot."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="13">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Audio" />
                                <ComboBox
                                    x:Name="AudioDeviceComboBox"
                                    AutomationProperties.HelpText="Choose the microphone Shruti uses for local dictation."
                                    Header="Microphone"
                                    IsEnabled="False"
                                    PlaceholderText="Loading microphones"
                                    SelectionChanged="AudioDeviceComboBox_SelectionChanged" />
                                <ComboBox x:Name="AudioRetentionComboBox" AutomationProperties.HelpText="Choose whether recordings are deleted after transcription, kept locally, or confirmed each time." Header="Audio retention" SelectionChanged="AudioRetentionComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Delete after transcription" Tag="DeleteAfterTranscription" />
                                    <ComboBoxItem Content="Keep recordings" Tag="Keep" />
                                    <ComboBoxItem Content="Ask each time" Tag="AskEveryTime" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="13">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Transcription" />
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        x:Name="BackendPreferenceComboBox"
                                        AutomationProperties.HelpText="Choose Auto unless a specific backend is required for troubleshooting."
                                        Header="Backend preference"
                                        SelectionChanged="BackendPreferenceComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Auto" Tag="Auto" />
                                        <ComboBoxItem Content="NPU" Tag="Npu" />
                                        <ComboBoxItem Content="GPU" Tag="Gpu" />
                                        <ComboBoxItem Content="CPU" Tag="Cpu" />
                                    </ComboBox>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Active provider/backend/device" />
                                        <TextBlock x:Name="ActiveBackendText" Style="{StaticResource MutedTextStyle}" FontSize="12" Text="Checking readiness" />
                                    </StackPanel>
                                </Grid>
                                <CheckBox
                                    x:Name="AllowSlowTranscriptionCheckBox"
                                    AutomationProperties.HelpText="Allow transcription even when the selected model/backend is slower than real time."
                                    Click="AllowSlowTranscriptionCheckBox_Click"
                                    Content="Allow slower-than-real-time transcription" />
                                <TextBlock
                                    x:Name="BackendReadinessText"
                                    AutomationProperties.LiveSetting="Polite"
                                    Style="{StaticResource MutedTextStyle}"
                                    FontSize="12"
                                    TextWrapping="Wrap"
                                    Text="Backend readiness has not been checked yet." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="13">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Activation" />
                                <CheckBox
                                    x:Name="PushToTalkCheckBox"
                                    AutomationProperties.HelpText="Enable the hold shortcut for push-to-talk dictation."
                                    Click="TriggerConfigurationCheckBox_Click"
                                    Content="Enable hold-to-dictate shortcut"
                                    IsChecked="True" />
                                <TextBox
                                    x:Name="PushToTalkKeyTextBox"
                                    AutomationProperties.HelpText="Shortcut held while speaking."
                                    Header="Hold shortcut"
                                    Text="Ctrl+Win+Space"
                                    LostFocus="TriggerConfigurationInput_LostFocus" />
                                <CheckBox
                                    x:Name="FloatingButtonCheckBox"
                                    AutomationProperties.HelpText="Show or hide the floating microphone control at startup."
                                    Click="TriggerConfigurationCheckBox_Click"
                                    Content="Show the floating microphone control at startup"
                                    IsChecked="True" />
                                <CheckBox
                                    x:Name="FloatingWindowShortcutCheckBox"
                                    AutomationProperties.HelpText="Enable a shortcut to show or hide the floating microphone window."
                                    Click="TriggerConfigurationCheckBox_Click"
                                    Content="Enable floating-window shortcut"
                                    IsChecked="True" />
                                <TextBox
                                    x:Name="FloatingWindowShortcutTextBox"
                                    AutomationProperties.HelpText="Shortcut that toggles the floating microphone window."
                                    Header="Toggle floating window shortcut"
                                    Text="Ctrl+Alt+M"
                                    LostFocus="TriggerConfigurationInput_LostFocus" />
                                <TextBlock
                                    Style="{StaticResource MutedTextStyle}"
                                    FontSize="12"
                                    Text="Press once to show the floating control; press again to hide it for this session." />
                                <CheckBox
                                    x:Name="TrayMenuCheckBox"
                                    AutomationProperties.HelpText="Allow dictation commands from the Windows tray menu."
                                    Click="TriggerConfigurationCheckBox_Click"
                                    Content="Enable dictation commands from the tray menu"
                                    IsChecked="True" />
                                <TextBlock
                                    Style="{StaticResource MutedTextStyle}"
                                    FontSize="12"
                                    Text="The tray icon stays available so you can restore Shruti or exit the process." />
                                <CheckBox
                                    x:Name="GlobalHotkeyCheckBox"
                                    AutomationProperties.HelpText="Enable a single-press global dictation shortcut."
                                    Click="TriggerConfigurationCheckBox_Click"
                                    Content="Enable single-press global trigger"
                                    IsChecked="False" />
                                <TextBox
                                    x:Name="HotkeyGestureTextBox"
                                    AutomationProperties.HelpText="Shortcut that starts or stops dictation."
                                    Header="Single-press shortcut"
                                    Text="Ctrl+Win+Space"
                                    LostFocus="TriggerConfigurationInput_LostFocus" />
                                <TextBlock x:Name="TriggerStatusText" Style="{StaticResource MutedTextStyle}" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="17" FontWeight="SemiBold" Text="Future controls" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" FontSize="12" Text="These controls are mock. They will be enabled once their backing features are implemented." />
                                <CheckBox Content="Start Shruti minimized" IsEnabled="False" />
                                <CheckBox Content="Restore focus before inserting text" IsEnabled="False" />
                                <CheckBox Content="Warn before the audio duration limit" IsEnabled="False" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
