<Window
    x:Class="Shruti.App.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Shruti">

    <Grid
        x:Name="Root"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Auto"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Grid
                MinWidth="420"
                Padding="28"
                RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="Shruti" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Local dictation" />
                    </StackPanel>

                    <Button
                        x:Name="SettingsButton"
                        Grid.Column="1"
                        MinWidth="108"
                        HorizontalAlignment="Right"
                        Click="SettingsButton_Click"
                        Content="Settings" />
                </Grid>

                <Grid
                    Grid.Row="1"
                    ColumnSpacing="16"
                    RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="State" />
                        <TextBlock
                            x:Name="StateText"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Idle" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Status" />
                        <TextBlock
                            x:Name="StatusText"
                            Text="Ready"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ComboBox
                        x:Name="InsertionModeComboBox"
                        Grid.Column="2"
                        Header="Insertion mode"
                        SelectionChanged="InsertionModeComboBox_SelectionChanged">
                        <ComboBoxItem
                            Content="Auto insert"
                            Tag="AutoInsert" />
                        <ComboBoxItem
                            Content="Preview first"
                            Tag="PreviewFirst" />
                        <ComboBoxItem
                            Content="Copy only"
                            Tag="CopyOnly" />
                    </ComboBox>

                    <StackPanel
                        Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Target" />
                        <TextBlock
                            x:Name="TargetText"
                        Text="No target captured"
                        TextWrapping="Wrap" />
                    </StackPanel>

                    <ComboBox
                        x:Name="AudioDeviceComboBox"
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Header="Microphone"
                        IsEnabled="False"
                        PlaceholderText="Loading microphones"
                        SelectionChanged="AudioDeviceComboBox_SelectionChanged" />

                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="2"
                        Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Input level" />
                        <ProgressBar
                            x:Name="AudioLevelBar"
                            Maximum="100"
                            Minimum="0"
                            Value="0" />
                    </StackPanel>
                </Grid>

                <Grid
                    x:Name="SettingsPanel"
                    Grid.Row="2"
                    ColumnSpacing="16"
                    RowSpacing="10"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox
                        x:Name="ThemeComboBox"
                        Header="Theme"
                        MinWidth="220"
                        SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem
                            Content="Use Windows setting"
                            Tag="Default" />
                        <ComboBoxItem
                            Content="Light"
                            Tag="Light" />
                        <ComboBoxItem
                            Content="Dark"
                            Tag="Dark" />
                    </ComboBox>

                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="System theme is used by default."
                        TextWrapping="Wrap" />

                    <Grid
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="HotkeyGestureTextBox"
                            Header="Global hotkey"
                            LostFocus="TriggerConfigurationInput_LostFocus"
                            Text="Ctrl+Alt+Space" />
                        <TextBox
                            x:Name="PushToTalkKeyTextBox"
                            Grid.Column="1"
                            Header="Push-to-talk key"
                            LostFocus="TriggerConfigurationInput_LostFocus"
                            Text="RightControl" />
                    </Grid>

                    <Grid
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        ColumnSpacing="12"
                        RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <CheckBox
                            x:Name="GlobalHotkeyCheckBox"
                            Click="TriggerConfigurationCheckBox_Click"
                            Content="Global hotkey"
                            IsChecked="True" />
                        <CheckBox
                            x:Name="PushToTalkCheckBox"
                            Grid.Column="1"
                            Click="TriggerConfigurationCheckBox_Click"
                            Content="Push to talk"
                            IsChecked="True" />
                        <CheckBox
                            x:Name="FloatingButtonCheckBox"
                            Grid.Row="1"
                            Click="TriggerConfigurationCheckBox_Click"
                            Content="Floating button"
                            IsChecked="True" />
                        <CheckBox
                            x:Name="TrayMenuCheckBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Click="TriggerConfigurationCheckBox_Click"
                            Content="Tray menu"
                            IsChecked="True" />
                    </Grid>

                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Audio is deleted after transcription by default."
                        TextWrapping="Wrap" />

                    <ComboBox
                        x:Name="AudioRetentionComboBox"
                        Grid.Row="3"
                        Header="Audio retention"
                        MinWidth="220"
                        SelectionChanged="AudioRetentionComboBox_SelectionChanged">
                        <ComboBoxItem
                            Content="Delete after transcription"
                            Tag="DeleteAfterTranscription" />
                        <ComboBoxItem
                            Content="Keep recordings"
                            Tag="Keep" />
                        <ComboBoxItem
                            Content="Ask each time"
                            Tag="AskEveryTime" />
                    </ComboBox>

                    <TextBlock
                        x:Name="TriggerStatusText"
                        Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </Grid>

                <ScrollViewer
                    Grid.Row="3"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Auto"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            x:Name="PrimaryDictationButton"
                            MinWidth="120"
                            Click="PrimaryDictationButton_Click"
                            Content="Start" />
                        <Button
                            x:Name="PauseButton"
                            MinWidth="96"
                            Click="PauseButton_Click"
                            Content="Pause" />
                        <Button
                            x:Name="CancelButton"
                            MinWidth="96"
                            Click="CancelButton_Click"
                            Content="Cancel" />
                        <Button
                            x:Name="RetryButton"
                            MinWidth="96"
                            Click="RetryButton_Click"
                            Content="Retry" />
                        <Button
                            x:Name="CopyButton"
                            MinWidth="96"
                            Click="CopyButton_Click"
                            Content="Copy" />
                        <Button
                            x:Name="InsertPreviewButton"
                            MinWidth="96"
                            Click="InsertPreviewButton_Click"
                            Content="Insert" />
                    </StackPanel>
                </ScrollViewer>

                <Grid
                    Grid.Row="4"
                    RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        x:Name="TranscriptPreviewBox"
                        AcceptsReturn="True"
                        Header="Transcript"
                        IsReadOnly="True"
                        MinHeight="180"
                        TextWrapping="Wrap" />

                    <CheckBox
                        x:Name="ReplaceSelectionCheckBox"
                        Grid.Row="1"
                        Content="Replace selected text"
                        Visibility="Collapsed" />

                    <TextBlock
                        x:Name="UserMessageText"
                        Grid.Row="2"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Dictation is ready."
                        TextWrapping="Wrap" />

                    <TextBlock
                        x:Name="ErrorText"
                        Grid.Row="3"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
